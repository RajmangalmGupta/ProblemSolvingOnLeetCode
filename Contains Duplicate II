class Solution {
    public boolean containsNearbyDuplicate(int[] nums, int k) {
        HashSet<Integer> set = new HashSet<>();
        for (int i = 0; i < nums.length; i++) {
            int val = nums[i];
            if(i>k){
                set.remove(i-k-1);
            }
            else if (set.contains(val)) {
                return true;
            }
            set.add(val);
        }
        return false;   
    }    
}
